# Mẫu biến môi trường — SAO CHÉP thành .env.local và điền giá trị thật.
# KHÔNG commit .env / .env*.local (đã bị .gitignore chặn).
# Tên biến phải khớp với lib/env.ts. Đổi cho phù hợp dự án của bạn.

# ── CÔNG KHAI (an toàn để lộ ra client — bắt buộc tiền tố NEXT_PUBLIC_) ──
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# URL gốc của site (dùng cho sitemap/robots/metadata)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── BÍ MẬT (chỉ server — KHÔNG để tiền tố NEXT_PUBLIC_) ──
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Tùy chọn ──
# SENTRY_DSN="https://...ingest.sentry.io/..."
# Analytics (chọn nhà cung cấp — xem BO-SUNG-nang-cao mục 7; đổi tên cho khớp):
# NEXT_PUBLIC_ANALYTICS_ID="..."
